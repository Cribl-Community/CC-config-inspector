    "/search/jobs": {
      "get": {
        "operationId": "listSearchJob",
        "x-cribl-internal": false,
        "x-cribl-availability": "cloud",
        "x-speakeasy-name-override": "list",
        "tags": [
          "search"
        ],
        "summary": "List all search jobs (Cribl.Cloud only)",
        "description": "Get a list of all search jobs (Cribl.Cloud only). Supports filtering, sorting, and pagination.",
        "responses": {
          "200": {
            "description": "Matching search jobs or abbreviated rows when <code>output=short</code>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountedSearchJob"
                },
                "examples": {
                  "SearchJobListResponseExamplesFullJobRow": {
                    "$ref": "#/components/examples/SearchJobListResponseExamplesFullJobRow"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed (missing or invalid credentials or Bearer token)."
          },
          "500": {
            "description": "Unexpected server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "output",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Output format. Use <code>short</code> to return abbreviated job information."
          },
          {
            "name": "id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Filter by job IDs. Can specify multiple IDs."
          },
          {
            "name": "earliest",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter jobs by earliest time."
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/SearchJobType"
            },
            "description": "Filter by job type."
          },
          {
            "name": "sortExp",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sorting expression to evaluate against jobs to specify the sort order."
          },
          {
            "name": "sortDir",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sort direction. Use <code>asc</code> or <code>desc</code>. Defaults to <code>asc</code>."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Maximum number of jobs to return. Use with <code>offset</code> to paginate results."
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Starting point from which to retrieve results. Use with <code>limit</code> to paginate results."
          },
          {
            "name": "latest",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter jobs by latest time. Used when <code>output=short</code>."
          },
          {
            "name": "correlationId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by correlation ID. Used when <code>output=short</code>."
          },
          {
            "name": "groupByCorrelationId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Group scheduled searches by correlation ID. Used when <code>output=short</code>."
          },
          {
            "name": "filterExp",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter expression to evaluate against jobs for inclusion in the response. Used when <code>output=short</code>."
          },
          {
            "name": "totalEventCount",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Include total event count in response. Used when <code>output=short</code>."
          },
          {
            "name": "includeSavedQueryNames",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Include saved query names in response. Used when <code>output=short</code>."
          }
        ],
        "x-speakeasy-pagination": {
          "type": "offsetLimit",
          "inputs": [
            {
              "name": "offset",
              "in": "parameters",
              "type": "offset"
            },
            {
              "name": "limit",
              "in": "parameters",
              "type": "limit"
            }
          ],
          "outputs": {
            "results": "$.items"
          }
        }
      },
      "post": {
        "operationId": "createSearchJob",
        "x-cribl-internal": false,
        "x-cribl-availability": "cloud",
        "x-speakeasy-name-override": "create",
        "tags": [
          "search"
        ],
