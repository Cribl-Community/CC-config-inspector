          "description": "CreateSearchJobSchema object.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSearchJobSchema"
              },
              "examples": {
                "SearchJobCreateExamplesMinimal": {
                  "$ref": "#/components/examples/SearchJobCreateExamplesMinimal"
                },
                "SearchJobCreateExamplesWithTimeRange": {
                  "$ref": "#/components/examples/SearchJobCreateExamplesWithTimeRange"
                },
                "SearchJobCreateExamplesEventContext": {
                  "$ref": "#/components/examples/SearchJobCreateExamplesEventContext"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A list containing the created search job object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountedSearchJob"
                },
                "examples": {
                  "SearchJobCreateResponseExamplesSyntheticCompleted": {
                    "$ref": "#/components/examples/SearchJobCreateResponseExamplesSyntheticCompleted"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query or request validation failure."
          },
          "401": {
            "description": "Authentication failed (missing or invalid credentials or Bearer token)."
          },
          "429": {
            "description": "Search limit or concurrency guardrail exceeded."
          },
          "500": {
            "description": "Unexpected server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
